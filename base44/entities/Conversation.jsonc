{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "user_id": { "type": "string" },
    "customer_id": { "type": "string" },
    "phone": { "type": "string" },
    "display_name": { "type": "string" },
    "language": { "type": "string", "enum": ["es", "en", "de", "fr"] },
    "order_ids": { "type": "array", "items": { "type": "string" } },
    "unread_count": { "type": "number", "default": 0 },
    "admin_unread_count": { "type": "number", "default": 0 },
    "customer_unread_count": { "type": "number", "default": 0 },
    "last_message_at": { "type": "string" },
    "service_window_expires_at": { "type": "string" },
    "automation_enabled": {
      "type": "boolean",
      "default": false,
      "rls": {
        "read": { "user_condition": { "role": "admin" } },
        "write": { "user_condition": { "role": "admin" } }
      }
    },
    "intake_status": {
      "type": "string",
      "enum": ["idle", "collecting", "created", "needs_admin"],
      "default": "idle"
    },
    "intake_draft": {
      "type": "object",
      "rls": {
        "read": { "user_condition": { "role": "admin" } },
        "write": { "user_condition": { "role": "admin" } }
      },
      "properties": {
        "service_type": { "type": "string" },
        "original_text": { "type": "string" },
        "translated_text": { "type": "string" },
        "delivery_address": { "type": "string" },
        "preferred_schedule": { "type": "string" },
        "client_notes": { "type": "string" }
      }
    },
    "intake_missing_fields": {
      "type": "array",
      "items": { "type": "string" },
      "rls": {
        "read": { "user_condition": { "role": "admin" } },
        "write": { "user_condition": { "role": "admin" } }
      }
    },
    "last_intake_order_id": {
      "type": "string",
      "rls": {
        "read": { "user_condition": { "role": "admin" } },
        "write": { "user_condition": { "role": "admin" } }
      }
    }
  },
  "required": ["phone"],
  "rls": {
    "create": { "user_condition": { "role": "admin" } },
    "read": {
      "$or": [
        { "data.user_id": "{{user.id}}" },
        { "user_condition": { "role": "admin" } }
      ]
    },
    "update": { "user_condition": { "role": "admin" } },
    "delete": { "user_condition": { "role": "admin" } }
  }
}
