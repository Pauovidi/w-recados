# La demo funciona sin variables y no realiza cargos ni envía WhatsApp reales.
VITE_DATA_PROVIDER=demo
VITE_DEMO_MODE=true
VITE_WHATSAPP_PHONE=34600000000

# Activar únicamente al conectar el proyecto real de Base44.
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=

# Secretos de backend: configurarlos en Base44, nunca con prefijo VITE_.
# PUBLIC_APP_URL=https://tu-dominio.example
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_WHATSAPP_FROM=+34...
# TWILIO_INBOUND_WEBHOOK_URL=https://tu-dominio.example/functions/twilioInbound
# TWILIO_STATUS_WEBHOOK_URL=https://tu-dominio.example/functions/twilioStatus
